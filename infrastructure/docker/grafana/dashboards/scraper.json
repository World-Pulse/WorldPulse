        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(worldpulse_scraper_errors_total{tier=\"1\"}[5m]) / clamp_min(rate(worldpulse_scraper_signals_total{tier=\"1\"}[5m]) + rate(worldpulse_scraper_errors_total{tier=\"1\"}[5m]), 1e-9)",
          "legendFormat": "tier-1 error %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(worldpulse_scraper_errors_total{tier=\"2\"}[5m]) / clamp_min(rate(worldpulse_scraper_signals_total{tier=\"2\"}[5m]) + rate(worldpulse_scraper_errors_total{tier=\"2\"}[5m]), 1e-9)",
          "legendFormat": "tier-2 error %",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(worldpulse_scraper_errors_total{tier=\"3\"}[5m]) / clamp_min(rate(worldpulse_scraper_signals_total{tier=\"3\"}[5m]) + rate(worldpulse_scraper_errors_total{tier=\"3\"}[5m]), 1e-9)",
