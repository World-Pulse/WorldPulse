        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(worldpulse_scraper_signals_total{tier=\"3\"}[2m])",
          "legendFormat": "tier-3",
          "refId": "D"
        }
      ],
