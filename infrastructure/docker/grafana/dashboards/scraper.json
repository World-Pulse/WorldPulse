        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (topic) (rate(kafka_topic_partition_current_offset{topic=~\"signals\\.raw|signals\\.verified|events\\.breaking\"}[2m]))",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Total ingestion rate (stacked)",
