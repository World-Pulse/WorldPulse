      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kafka_consumergroup_lag{topic=\"signals.verified\"})",
          "legendFormat": "signals.verified lag",
          "refId": "A"
        }
      ],
      "title": "signals.verified lag (alert threshold: 1000)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
