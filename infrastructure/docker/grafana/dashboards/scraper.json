        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(worldpulse_scraper_pipeline_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(worldpulse_scraper_pipeline_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
