# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.next/
out/
build/

# Environment — NEVER commit these
# Pre-commit reminder: run `git secrets --scan` or `grep -r "sk-\|ghp_\|AKIA" .` before pushing
.env
.env.local
.env.production
.env.prod
.env.*.local
.env.staging
*.pem
*.key
secrets/

# Certs — managed by certbot on server
.certbot/
nginx/certs/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# TypeScript build info cache
*.tsbuildinfo

# packages/types emits declarations alongside source — exclude compiled outputs
packages/types/src/*.js
packages/types/src/*.js.map
packages/types/src/*.d.ts
packages/types/src/*.d.ts.map

# Misc
*.tmp
coverage/
.github/
