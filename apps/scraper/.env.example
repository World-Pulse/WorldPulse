# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL=postgresql://wp_user:wp_secret_local@localhost:5432/worldpulse_db

# ─── CACHE ────────────────────────────────────────────────
REDIS_URL=redis://:wp_redis_local@localhost:6379

# ─── MESSAGE QUEUE ────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── SCRAPER ──────────────────────────────────────────────
SCRAPE_INTERVAL_MS=30000
# Max concurrent source scrapes per cycle (default: 10)
SCRAPER_CONCURRENCY=10
# Max requests per second per domain (default: 1)
SCRAPER_RATE_LIMIT_RPS=1
LOG_LEVEL=debug
NODE_ENV=development

# ─── OSINT SIGNAL SOURCES ─────────────────────────────────
# GDELT Project (https://www.gdeltproject.org/) — no API key required
# Polling interval in milliseconds (default: 15 minutes)
GDELT_INTERVAL_MS=900000

# OpenSky Network ADS-B (https://opensky-network.org/) — no API key required
# Polling interval in milliseconds (default: 5 minutes)
ADSB_INTERVAL_MS=300000

# AIS Vessel Tracking via aisstream.io (https://aisstream.io/)
# Free tier available — register at aisstream.io for a free API key
# Leave unset to disable AIS tracking
# AIS_STREAM_API_KEY=your_aisstream_api_key_here

# USGS Earthquake Feed (https://earthquake.usgs.gov/) — no API key required
# Polling interval in milliseconds (default: 5 minutes)
SEISMIC_INTERVAL_MS=300000

# NASA FIRMS Fire Hotspot Feed (https://firms.modaps.eosdis.nasa.gov/) — no API key required
# Polling interval in milliseconds (default: 30 minutes)
FIRMS_INTERVAL_MS=1800000

# NOAA Space Weather Alerts (https://www.swpc.noaa.gov/) — no API key required
# Polling interval in milliseconds (default: 10 minutes)
SPACEWEATHER_INTERVAL_MS=600000

# GPSJam.org GPS Jamming Feed (https://gpsjam.org/) — no API key required
# Polling interval in milliseconds (default: 15 minutes)
GPSJAM_INTERVAL_MS=900000
# Minimum jamming probability threshold 0.0-1.0 (default: 0.6 = 60%)
GPSJAM_MIN_PCT=0.6
# Maximum signals to create per poll cycle (default: 10)
GPSJAM_MAX_SIGNALS=10

# IODA Internet Outage Monitoring (https://ioda.caida.org/) — no API key required
# Powered by Georgia Tech / CAIDA BGP + active probing + network telescope
# Polling interval in milliseconds (default: 10 minutes)
IODA_INTERVAL_MS=600000
# Minimum anomaly score threshold (default: 30, higher = worse outage)
IODA_MIN_SCORE=30
# Lookback window in seconds per poll (default: 600 = 10 min)
IODA_LOOKBACK_S=600
