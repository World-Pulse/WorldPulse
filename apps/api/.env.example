# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL=postgresql://wp_user:wp_secret_local@localhost:5432/worldpulse_db

# ─── CACHE ────────────────────────────────────────────────
REDIS_URL=redis://:wp_redis_local@localhost:6379

# ─── MESSAGE QUEUE ────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── SEARCH ───────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_KEY=wp_meili_local_key

# ─── ANALYTICS (ClickHouse) ───────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=worldpulse
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# ─── AUTH ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── SERVER ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ─── AI Signal Summaries (optional — falls back to extractive summarization) ──
# Option 1: OpenAI (uses gpt-4o-mini by default — low cost, ~$0.0001/summary)
# OPENAI_API_KEY=sk-...
#
# Option 2: Local Ollama instance (zero cost, requires ollama + llama3.2)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
#
# If neither is set, WorldPulse uses fast extractive summarization (always available)

# ─── OAUTH (optional) ─────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
