# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL=postgresql://wp_user:wp_secret_local@localhost:5432/worldpulse

# ─── CACHE ────────────────────────────────────────────────
REDIS_URL=redis://:wp_redis_local@localhost:6379

# ─── MESSAGE QUEUE ────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── SEARCH ───────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_KEY=wp_meili_local_key

# ─── AUTH ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── SERVER ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ─── AI (optional, falls back to rule-based) ──────────────
# LLM_API_URL=http://localhost:11434/api/generate
# LLM_MODEL=llama3.2
# OPENAI_API_KEY=sk-...  (alternative: OpenAI-compatible API)

# ─── OAUTH (optional) ─────────────────────────────────────
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
