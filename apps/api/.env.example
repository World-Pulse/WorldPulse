# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL=postgresql://wp_user:wp_secret_local@localhost:5432/worldpulse_db

# ─── CACHE ────────────────────────────────────────────────
REDIS_URL=redis://:wp_redis_local@localhost:6379

# ─── MESSAGE QUEUE ────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── SEARCH ───────────────────────────────────────────────
MEILI_HOST=http://localhost:7700
MEILI_KEY=wp_meili_local_key

# ─── ANALYTICS (ClickHouse) ───────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=worldpulse
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=

# ─── AUTH ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── SERVER ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# ─── AI Signal Summaries (optional — falls back to extractive summarization) ──
# Priority order: Anthropic → OpenAI → Gemini → OpenRouter → Ollama → extractive
#
# Option 1: Anthropic Claude (claude-haiku-4-5-20251001 — fast, low cost)
# ANTHROPIC_API_KEY=sk-ant-...
#
# Option 2: OpenAI (uses gpt-4o-mini by default — low cost, ~$0.0001/summary)
# OPENAI_API_KEY=sk-...
#
# Option 3: Google Gemini (gemini-2.0-flash — free tier available)
# GEMINI_API_KEY=AIza...
#
# Option 4: OpenRouter (access 100+ models via single API key)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
#
# Option 5: Local Ollama instance (zero cost, requires ollama + llama3.2)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
#
# If none are set, WorldPulse uses fast extractive summarization (always available)

# ─── OSINT POLLER INTERVALS (optional — milliseconds) ────────────────────────
# CelesTrak satellite catalog polling interval (default: 30 minutes)
# CELESTRAK_POLL_INTERVAL_MS=1800000
# UN Comtrade strategic commodity flows polling interval (default: 60 minutes)
# COMTRADE_INTERVAL_MS=3600000
# USPTO PatentsView defense/dual-use patent intelligence (default: 60 minutes)
# USPTO_PATENTS_INTERVAL_MS=3600000

# ─── PULSE AI Bureau ─────────────────────────────────────
# Enable the PULSE autonomous editorial system
# PULSE_ENABLED=true
# PULSE_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# PULSE_OPENAI_MODEL=gpt-4o-mini

# ─── TWITTER/X AUTO-PUBLISHER (optional) ─────────────────
# Register at developer.x.com → Free tier = 1,500 tweets/month
# The PULSE Twitter agent auto-posts flash briefs, daily briefings,
# and analysis threads to your @WorldPulse_io account.
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=

# ─── OAUTH (optional) ─────────────────────────────────────
# Register a GitHub OAuth App at https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3001/api/v1/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/v1/auth/github/callback
FRONTEND_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
