# ─── WorldPulse Web — Environment Variables ───────────────────────────────────
# Copy this file to .env.local for local development:
#   cp apps/web/.env.example apps/web/.env.local
#
# For Vercel deployments, these are set in the Vercel dashboard under
# Project → Settings → Environment Variables. Never commit .env.local or
# .env.production.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ─── API Connectivity ─────────────────────────────────────────────────────────

# Base URL of the WorldPulse Fastify API (no trailing slash)
# Local dev: http://localhost:3001  |  Production: https://api.world-pulse.io
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL for real-time signal streaming
# Local dev: ws://localhost:3001  |  Production: wss://api.world-pulse.io
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ─── Application ─────────────────────────────────────────────────────────────

# App version shown in footer and error reports (optional, auto-detected from package.json)
NEXT_PUBLIC_APP_VERSION=

# ─── Sentry Error Tracking ───────────────────────────────────────────────────
# Get your DSN from https://sentry.io (Project → Settings → Client Keys)
# Leave blank in development to disable error tracking.

# Client-side Sentry DSN (safe to expose, it's a public key)
NEXT_PUBLIC_SENTRY_DSN=

# Server-side Sentry DSN (same value — Sentry DSNs are public)
SENTRY_DSN=

# Percentage of transactions to send to Sentry for performance monitoring (0.0–1.0)
NEXT_PUBLIC_SENTRY_TRACES_RATE=0.1

# Percentage of sessions to record for Session Replay in production (0.0–1.0)
NEXT_PUBLIC_SENTRY_REPLAY_RATE=0.0

# Percentage of sessions with errors to record for Session Replay (0.0–1.0)
NEXT_PUBLIC_SENTRY_ERROR_REPLAY_RATE=1.0

# ─── PostHog Product Analytics ───────────────────────────────────────────────
# Get your project API key from https://app.posthog.com (Project → Settings)
# Leave blank to disable analytics (safe for local development).

# Client-side PostHog project API key (safe to expose)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostHog ingestion host (default: https://app.posthog.com, or your self-hosted URL)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Development Only ────────────────────────────────────────────────────────
# These variables are only relevant for local development and are NOT used
# in production Vercel deployments.

# NODE_ENV is automatically set by Next.js (development | production | test)
# NODE_ENV=development
