{
  "manifest_version": 3,
  "name": "WorldPulse Signal Verifier",
  "version": "1.0.0",
  "description": "Inline signal verification from the WorldPulse intelligence network — hover over selected text to see real-time fact-checking and reliability scores.",
  "browser_specific_settings": {
    "gecko": {
      "id": "worldpulse-signal-verifier@worldpulse.io",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": [
        "https://worldpulse.io/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WorldPulse Signal Verifier",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
