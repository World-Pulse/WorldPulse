
# ─── ACLED CONFLICT DATA ──────────────────────────────────
# ACLED conflict/protest event data. Free public API for recent events.
# Optional: register at https://developer.acleddata.com for higher rate limits.
# ACLED_API_KEY=your_acled_api_key
# ACLED_API_EMAIL=your_email@example.com
# ACLED_INTERVAL_MS=1800000

# ─── SAFECAST RADIATION ──────────────────────────────────
# Safecast crowdsourced radiation monitoring. Free, no auth required.
# SAFECAST_INTERVAL_MS=1800000

# ─── CISA KEV CYBERSECURITY ──────────────────────────────
# CISA Known Exploited Vulnerabilities catalog. Free, no auth required.
# CISA_KEV_INTERVAL_MS=1800000

# ─── OFAC SANCTIONS ─────────────────────────────────────
# US Treasury OFAC sanctions designations. Free, no auth required.
# Tracks Specially Designated Nationals (SDN) list updates.
# OFAC_INTERVAL_MS=1800000

# ─── UN RELIEFWEB HUMANITARIAN ──────────────────────────
# UN OCHA ReliefWeb disasters API. Free, no auth required.
# Tracks humanitarian crises, natural disasters, epidemics.
# RELIEFWEB_INTERVAL_MS=1800000

# ─── NWS SEVERE WEATHER ──────────────────────────────────
# NOAA National Weather Service severe weather CAP alerts. Free, no auth required.
# Tracks tornadoes, hurricanes, severe thunderstorms, flooding, blizzards.
# NWS_INTERVAL_MS=600000

# ─── ALIENVAULT OTX THREAT INTELLIGENCE ──────────────────
# AlienVault OTX community threat intelligence. Free tier: 10K req/day.
# Optional API key for higher rate limits + subscribed pulse feed.
# OTX_API_KEY=your_otx_api_key_here
# OTX_INTERVAL_MS=1800000

# ─── USGS/GVP VOLCANIC ACTIVITY ─────────────────────────
# USGS Volcano Hazards Program & Smithsonian GVP. Free, no auth required.
# Tracks eruptions, volcanic unrest, aviation color codes.
# GVP_INTERVAL_MS=1800000

# ─── EU CFSP SANCTIONS ────────────────────────────────────
# European Council CFSP sanctions regimes. Free, no auth required.
# Complements OFAC with European sanctions perspective.
# EU_SANCTIONS_INTERVAL_MS=3600000

# ─── POWER GRID OUTAGES ──────────────────────────────────
# US power grid disruption monitoring via PowerOutage.us.
# Crowdsourced data, free, no auth required.
# POWER_OUTAGE_INTERVAL_MS=1800000

# ─── AVIATION SAFETY INCIDENTS ────────────────────────────
# Aviation Safety Network (ASN) accident/incident feed.
# Gold-standard aviation safety database, free RSS, no auth required.
# AVIATION_INTERVAL_MS=3600000

# ─── UNHCR DISPLACEMENT ──────────────────────────────────
# UNHCR population displacement situations. Free, no auth required.
# Tracks refugee movements, internal displacement, and statelessness crises.
# UNHCR_INTERVAL_MS=3600000

# ─── TSUNAMI WARNINGS ────────────────────────────────────
# NOAA National/Pacific Tsunami Warning Center Atom feeds.
# Life-safety bulletins. Free, no auth required.
# TSUNAMI_INTERVAL_MS=600000

# ─── INTERPOL RED NOTICES ─────────────────────────────────
# Interpol public Red Notices API. Free, no auth required.
# Tracks international wanted persons and law enforcement alerts.
# INTERPOL_INTERVAL_MS=3600000

# ─── OBSERVABILITY ────────────────────────────────────────
# Sentry (or self-hosted Glitchtip) for error tracking.
# 1. pnpm add @sentry/node --filter @worldpulse/api
# 2. Set your DSN below
# SENTRY_DSN=https://xxx@sentry.io/123
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry traces from scraper pipeline are emitted as structured pino logs.
# Integrate with Grafana Loki / Datadog / OpenSearch for trace correlation.
# To upgrade to real OTel SDK: pnpm add @opentelemetry/api @opentelemetry/sdk-trace-node --filter @worldpulse/scraper
