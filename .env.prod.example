# ─────────────────────────────────────────────────────────────────────────────
#  WorldPulse — Production Environment Variables
#
#  Copy to .env.prod and fill in every value before deploying.
#    cp .env.prod.example .env.prod
#
#  NEVER commit .env.prod to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Internal identifiers — do NOT rename these (breaks existing migrations/stack)
DB_NAME=worldpulse_db
DB_USER=wp_user
DB_PASSWORD=CHANGE_ME_strong_random_password_here

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ─── MEILISEARCH ──────────────────────────────────────────────────────────────
# Master key — keep secret, used by API internally
MEILI_KEY=CHANGE_ME_meili_master_key_min_16_chars

# Public/search-only key — safe to expose to frontend
# Generate with: curl -X GET 'http://localhost:7700/keys' -H 'Authorization: Bearer <MEILI_KEY>'
# After first boot, get the "Default Search API Key" value
MEILI_PUBLIC_KEY=CHANGE_ME_meili_public_search_key

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# ─── EMAIL / SMTP ─────────────────────────────────────────────────────────────
# Transactional email for verification, alerts, password reset
# Recommended: SendGrid, Postmark, Resend, or your own SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_sendgrid_api_key
EMAIL_FROM=noreply@world-pulse.io
# Server IP (for reference)
SERVER_IP=142.93.71.102

# ─── OAUTH (optional) ─────────────────────────────────────────────────────────
# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URLs (add both):
#   https://api.world-pulse.io/api/v1/auth/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create at https://console.cloud.google.com/
# Callback URLs (add both):
#   https://api.world-pulse.io/api/v1/auth/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── WEB PUSH / VAPID ─────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── STRIPE BILLING ──────────────────────────────────────────────────────────
# Pro plan checkout + subscription management
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=rk_live_CHANGE_ME
STRIPE_PRO_PRICE_ID=price_1TGt7r5h85I1AGiUu7qZFnCT
STRIPE_WEBHOOK_SECRET=whsec_cGTo4vk6EAyl5344FhQpaHYsZxHqBbJV

# ─── AI / LLM CLASSIFICATION (optional) ──────────────────────────────────────
# If set, scraper uses LLM for signal classification and fact-checking.
# Falls back to rule-based classification if unset.
#
# Option A — OpenAI
OPENAI_API_KEY=

# Option B — Self-hosted (Ollama, vLLM, etc.)
# LLM_API_URL=http://your-ollama-host:11434
# LLM_MODEL=llama3.2

# ─── TWITTER/X AUTO-PUBLISHER ────────────────────────────────────────────────
# PULSE auto-tweets flash briefs, daily briefings, and analysis to @WorldPulse_io
# Register at developer.x.com → Free tier = 1,500 tweets/month
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── SCRAPER ──────────────────────────────────────────────────────────────────
# How often to scrape sources (milliseconds). Default: 30 seconds
SCRAPE_INTERVAL_MS=30000

# ─── MONITORING ───────────────────────────────────────────────────────────────
# Grafana admin password (accessible at https://world-pulse.io/grafana)
# Generate with: openssl rand -hex 16
GRAFANA_PASSWORD=CHANGE_ME_grafana_admin_password
